{
  "compilerOptions": {
    "noEmit": true,
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": false,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "skipLibCheck": true,
    "allowJs": true,
    "allowImportingTsExtensions": true,
  },
  "exclude": [
    "node_modules",
    "assets"
  ]
}
